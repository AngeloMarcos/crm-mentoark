{
  "permissions": {
    "allow": [
      "Bash(dig *)",
      "Bash(sshpass -p 'Mentoark@2025' ssh *)",
      "Bash(sshpass -p 'Mentoark@2025' scp *)",
      "Bash(git fetch *)",
      "Bash(git push *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "PowerShell(ssh -o StrictHostKeyChecking=no root@147.93.9.172 *)",
      "PowerShell(scp -o StrictHostKeyChecking=no *)",
      "PowerShell(Get-ChildItem *)",
      "PowerShell(where.exe *)",
      "PowerShell(wsl -u root -- sshpass -p 'Mentoark@2025' ssh *)",
      "PowerShell(wsl -u root -- sshpass -p 'Mentoark@2025' scp *)",
      "PowerShell(wsl -u root -- sshpass *)",
      "PowerShell(wsl -u root -- apt-get *)",
      "PowerShell(wsl which *)",
      "PowerShell(wsl whoami *)",
      "PowerShell(wsl id *)",
      "PowerShell(Get-Command *)",
      "PowerShell(Test-Path *)",
      "PowerShell(Get-Module *)",
      "PowerShell(Install-Module *)",
      "PowerShell(Import-Module *)",
      "PowerShell(cd *)",
      "PowerShell(git status *)",
      "PowerShell(git diff *)",
      "PowerShell(git log *)",
      "PowerShell(git stash *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "timeout": 30,
            "statusMessage": "Verificando containers...",
            "command": "INPUT=$(cat); CMD=$(echo \"$INPUT\" | jq -r '.tool_input.command // \"\"'); if echo \"$CMD\" | grep -qE 'docker[[:space:]]+compose[[:space:]]+build|docker-compose[[:space:]]+build'; then STATUS=$(sshpass -p 'Mentoark@2025' ssh -o StrictHostKeyChecking=no root@147.93.9.172 'docker ps --format \"table {{.Names}}\\t{{.Image}}\\t{{.Status}}\"' 2>/dev/null); printf '{\"systemMessage\": %s}' \"$(printf 'Containers apos o build:\\n%s' \"$STATUS\" | jq -Rs .)\"; fi"
          }
        ]
      }
    ]
  }
}
